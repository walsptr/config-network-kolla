# Managed by Ansible. Do not edit manually.
network:
  version: {{ network_version }}
  renderer: {{ network_renderer }}
{% if network_resolved_ethernets | length > 0 %}
  ethernets:
{% for iface in network_resolved_ethernets %}
{% set iface_has_settings = iface.rename or iface.mtu is defined or iface.optional is defined or iface.dhcp4 is defined or iface.dhcp6 is defined or iface.addresses is defined or iface.gateway4 is defined or iface.gateway6 is defined or iface.nameservers is defined or iface.routes is defined %}
{% if iface_has_settings %}
    {{ iface.final_name }}:
{% else %}
    {{ iface.final_name }}: {}
{% endif %}
{% if iface.rename %}
      match:
        macaddress: "{{ iface.macaddress }}"
      set-name: "{{ iface.final_name }}"
{% endif %}
{% if iface.mtu is defined %}
      mtu: {{ iface.mtu }}
{% endif %}
{% if iface.optional is defined %}
      optional: {{ 'true' if iface.optional else 'false' }}
{% endif %}
{% if iface.dhcp4 is defined %}
      dhcp4: {{ 'true' if iface.dhcp4 else 'false' }}
{% endif %}
{% if iface.dhcp6 is defined %}
      dhcp6: {{ 'true' if iface.dhcp6 else 'false' }}
{% endif %}
{% if iface.addresses is defined and iface.addresses | length > 0 %}
      addresses:
{% for address in iface.addresses %}
        - {{ address }}
{% endfor %}
{% endif %}
{% if iface.gateway4 is defined %}
      gateway4: {{ iface.gateway4 }}
{% endif %}
{% if iface.gateway6 is defined %}
      gateway6: {{ iface.gateway6 }}
{% endif %}
{% if iface.nameservers is defined and ((iface.nameservers.addresses is defined and iface.nameservers.addresses | length > 0) or (iface.nameservers.search is defined and iface.nameservers.search | length > 0)) %}
      nameservers:
{% if iface.nameservers.addresses is defined and iface.nameservers.addresses | length > 0 %}
        addresses:
{% for address in iface.nameservers.addresses %}
          - {{ address }}
{% endfor %}
{% endif %}
{% if iface.nameservers.search is defined and iface.nameservers.search | length > 0 %}
        search:
{% for domain in iface.nameservers.search %}
          - {{ domain }}
{% endfor %}
{% endif %}
{% endif %}
{% if iface.routes is defined and iface.routes | length > 0 %}
      routes:
{% for route in iface.routes %}
        - to: {{ route.to }}
          via: {{ route.via }}
{% if route.metric is defined %}
          metric: {{ route.metric }}
{% endif %}
{% if route['on-link'] is defined %}
          on-link: {{ 'true' if route['on-link'] else 'false' }}
{% endif %}
{% endfor %}
{% endif %}
{% endfor %}
{% endif %}
{% if network_bonds | length > 0 %}
  bonds:
{% for bond in network_bonds %}
    {{ bond.name }}:
      interfaces:
{% for member in bond.interfaces %}
        - {{ member }}
{% endfor %}
{% if bond.mtu is defined %}
      mtu: {{ bond.mtu }}
{% endif %}
{% if bond.optional is defined %}
      optional: {{ 'true' if bond.optional else 'false' }}
{% endif %}
{% if bond.dhcp4 is defined %}
      dhcp4: {{ 'true' if bond.dhcp4 else 'false' }}
{% endif %}
{% if bond.dhcp6 is defined %}
      dhcp6: {{ 'true' if bond.dhcp6 else 'false' }}
{% endif %}
{% if bond.addresses is defined and bond.addresses | length > 0 %}
      addresses:
{% for address in bond.addresses %}
        - {{ address }}
{% endfor %}
{% endif %}
{% if bond.gateway4 is defined %}
      gateway4: {{ bond.gateway4 }}
{% endif %}
{% if bond.gateway6 is defined %}
      gateway6: {{ bond.gateway6 }}
{% endif %}
{% if bond.nameservers is defined and ((bond.nameservers.addresses is defined and bond.nameservers.addresses | length > 0) or (bond.nameservers.search is defined and bond.nameservers.search | length > 0)) %}
      nameservers:
{% if bond.nameservers.addresses is defined and bond.nameservers.addresses | length > 0 %}
        addresses:
{% for address in bond.nameservers.addresses %}
          - {{ address }}
{% endfor %}
{% endif %}
{% if bond.nameservers.search is defined and bond.nameservers.search | length > 0 %}
        search:
{% for domain in bond.nameservers.search %}
          - {{ domain }}
{% endfor %}
{% endif %}
{% endif %}
{% if bond.routes is defined and bond.routes | length > 0 %}
      routes:
{% for route in bond.routes %}
        - to: {{ route.to }}
          via: {{ route.via }}
{% if route.metric is defined %}
          metric: {{ route.metric }}
{% endif %}
{% if route['on-link'] is defined %}
          on-link: {{ 'true' if route['on-link'] else 'false' }}
{% endif %}
{% endfor %}
{% endif %}
{% if bond.parameters is defined and bond.parameters | length > 0 %}
      parameters:
{% for key, value in bond.parameters.items() %}
        {{ key }}: {{ value }}
{% endfor %}
{% endif %}
{% endfor %}
{% endif %}
{% if network_vlans | length > 0 %}
  vlans:
{% for vlan in network_vlans %}
    {{ vlan.name }}:
      id: {{ vlan.id }}
      link: {{ vlan.link }}
{% if vlan.mtu is defined %}
      mtu: {{ vlan.mtu }}
{% endif %}
{% if vlan.optional is defined %}
      optional: {{ 'true' if vlan.optional else 'false' }}
{% endif %}
{% if vlan.dhcp4 is defined %}
      dhcp4: {{ 'true' if vlan.dhcp4 else 'false' }}
{% endif %}
{% if vlan.dhcp6 is defined %}
      dhcp6: {{ 'true' if vlan.dhcp6 else 'false' }}
{% endif %}
{% if vlan.addresses is defined and vlan.addresses | length > 0 %}
      addresses:
{% for address in vlan.addresses %}
        - {{ address }}
{% endfor %}
{% endif %}
{% if vlan.gateway4 is defined %}
      gateway4: {{ vlan.gateway4 }}
{% endif %}
{% if vlan.gateway6 is defined %}
      gateway6: {{ vlan.gateway6 }}
{% endif %}
{% if vlan.nameservers is defined and ((vlan.nameservers.addresses is defined and vlan.nameservers.addresses | length > 0) or (vlan.nameservers.search is defined and vlan.nameservers.search | length > 0)) %}
      nameservers:
{% if vlan.nameservers.addresses is defined and vlan.nameservers.addresses | length > 0 %}
        addresses:
{% for address in vlan.nameservers.addresses %}
          - {{ address }}
{% endfor %}
{% endif %}
{% if vlan.nameservers.search is defined and vlan.nameservers.search | length > 0 %}
        search:
{% for domain in vlan.nameservers.search %}
          - {{ domain }}
{% endfor %}
{% endif %}
{% endif %}
{% if vlan.routes is defined and vlan.routes | length > 0 %}
      routes:
{% for route in vlan.routes %}
        - to: {{ route.to }}
          via: {{ route.via }}
{% if route.metric is defined %}
          metric: {{ route.metric }}
{% endif %}
{% if route['on-link'] is defined %}
          on-link: {{ 'true' if route['on-link'] else 'false' }}
{% endif %}
{% endfor %}
{% endif %}
{% endfor %}
{% endif %}
